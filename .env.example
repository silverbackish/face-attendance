MAIL_PASSWORD=xxxx xxxx xxxx xxxx

TEACHER_EMAIL=teacher@school.edu

# 12:30 UTC = 6:00pm IST
REPORT_HOUR_UTC=12
REPORT_MINUTE_UTC=30

FLASK_DEBUG=true
